# =============================================================================
# AI Captain Service - Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# App / Runtime
# -----------------------------------------------------------------------------
APP_NAME=ai-captain-service
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Enable/disable optional integrations
ENABLE_TELEGRAM_BOT=false
ENABLE_TELEGRAM_STRICT=false
ENABLE_TTS=false
ENABLE_STT=false
ENABLE_RECOVERY=false

# -----------------------------------------------------------------------------
# AI / LLM Configuration
# -----------------------------------------------------------------------------
# Google Gemini (required)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# Telegram Bot (required only if ENABLE_TELEGRAM_BOT=true)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Groq STT (required only if ENABLE_STT=true)
GROQ_API_KEY=your-groq-api-key-here
GROQ_STT_MODEL=whisper-large-v3

# ElevenLabs TTS (required only if ENABLE_TTS=true)
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
ELEVENLABS_VOICE_ID=your-voice-id-here
ELEVENLABS_MODEL_ID=eleven_monolingual_v1

# -----------------------------------------------------------------------------
# Laravel Backend Integration
# -----------------------------------------------------------------------------
# Base URL of Laravel backend (required)
LARAVEL_BACKEND_URL=http://localhost:8001
LARAVEL_CART_UPDATE_PATH=/api/v1/cart/update
LARAVEL_ABANDONED_CART_PATH=/api/v1/cart/abandoned

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# WebSocket Security
# -----------------------------------------------------------------------------
# JWT signing secret for WebSocket authentication (required)
WEBSOCKET_AUTH_SECRET=your-secret-key-for-jwt-signing-change-in-production
WEBSOCKET_AUTH_ALGORITHM=HS256

# -----------------------------------------------------------------------------
# Session / Recovery / HTTP Timing
# -----------------------------------------------------------------------------
SESSION_TTL_SECONDS=3600
AUDIO_BUFFER_TTL_SECONDS=300
RECOVERY_DELAY_SECONDS=900
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=3
HTTP_BACKOFF_BASE_SECONDS=1.0
MAX_AUDIO_BUFFER_BYTES=10000000

# -----------------------------------------------------------------------------
# CORS / Debug
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins
ALLOWED_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
ENABLE_DEBUG_ROUTES=false